# the testsuite for the qed library
qed.lib.tests.stem := qed.lib
# depends on
qed.ext.tests.prerequisites := qed.lib
# external dependencies
qed.lib.tests.extern := $(qed.lib.extern)

# each generator emits its fixture beside itself; record the outputs for the clean rules
tests.qed.lib.nisar.masks.gcov.clean += gcov.bmp
tests.qed.lib.nisar.masks.gunw.clean += gunw.bmp


# end of file
